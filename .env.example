# Core Application Configuration Template for Heimdall (Consumer Edition)
LOG_LEVEL=INFO
APP_VERSION=1.0.0

# Relational Database (PostgreSQL)
# For local dev via Docker PostgreSQL container:
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=newssphere
POSTGRES_USER=developer
POSTGRES_PASSWORD=LocalPassword123

# Connection URL overrides (e.g., Neon serverless PostgreSQL connection string)
# Format: postgresql+asyncpg://user:pass@ep-xxx.neon.tech/newssphere
DATABASE_URL=postgresql+asyncpg://developer:LocalPassword123@localhost:5433/newssphere

# Auth Configurations
JWT_SECRET=dev_secret_key_123_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Ingestion & Summarization Webhook
INGEST_SECRET=default_ingest_secret_change_me_to_something_secure
GEMINI_API_KEY=mock_key_for_testing
GEMINI_MODEL=gemini-2.0-flash

# CORS Allowed Origins (Comma-separated list of frontends)
ALLOWED_ORIGINS=http://localhost:3000,https://heimdall.vercel.app

# Recommender Tuning Parameters
COLD_START_MIN_READS=3
COMPLETION_BOOST=0.10
ABANDONMENT_PENALTY=0.10
FRESHNESS_HALF_LIFE_HOURS=24.0

# SMTP / Email Configuration for Password Reset
# Set these in production. If left empty, reset links print to logs/console instead.
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@yourdomain.com
SMTP_PASSWORD=smtp_password_here
SMTP_FROM_EMAIL=Heimdall Watchtower <no-reply@yourdomain.com>
FRONTEND_URL=http://localhost:3000
