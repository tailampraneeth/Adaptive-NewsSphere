# Core Application Configuration Template
LOG_LEVEL=INFO

# Relational Database (PostgreSQL inside Docker)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=newssphere
POSTGRES_USER=developer
POSTGRES_PASSWORD=LocalPassword123

# Computed Database URL (Using port 5433 to avoid conflict with native service)
DATABASE_URL=postgresql+asyncpg://developer:LocalPassword123@localhost:5433/newssphere

# Redis Cache Broker
REDIS_URL=redis://localhost:6379/0

# Qdrant Vector Search URL
QDRANT_URL=http://localhost:6333

# Google AI Studio API Key (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
